# ───────────────────────────────────────────────────────────────────────────────
# RPOS Environment Configuration
# Copy this file to .env and fill in your actual values.
# ───────────────────────────────────────────────────────────────────────────────

# API
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname # Required for Prisma migrations when using connection pooling
REDIS_URL=redis://localhost:6379 # Required for WebSockets and token caches
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# CORS — comma-separated list of allowed frontend origins (required for production)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Optional: Web Push VAPID keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Optional: WhatsApp Cloud API (Meta)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Optional: Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
